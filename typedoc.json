{
  "$schema": "https://typedoc.org/schema.json",
  "entryPointStrategy": "resolve",
  "entryPoints": [
    "./src/main.ts"
  ],
  "out": "docs",
  "name": "CF Workers Telegram Bot",
  "includeVersion": true,
  "excludeInternal": true,
  "skipErrorChecking": true,
  "hideGenerator": true,
  "searchInComments": true,
  "cleanOutputDir": true,
  "titleLink": "https://cf-workers-telegram-bot.codebam.ca",
  "githubPages": true,
  "plugin": [
    "typedoc-plugin-extras"
  ],
  "customDescription": "A lightweight, type-safe Telegram Bot library for Cloudflare Workers. Build and deploy bots with ease."
}