{
	"include": ["src/**/*"],
	"compilerOptions": {
		"strict": true,
		"target": "esnext",
		"module": "esnext",
		"lib": ["esnext"],
		"types": ["@cloudflare/workers-types"],
		"esModuleInterop": true,
		"allowSyntheticDefaultImports": true,
		"moduleResolution": "bundler",
		"rootDir": "../..",
		"resolveJsonModule": true,
		"allowJs": true,
		"forceConsistentCasingInFileNames": true,
		"declaration": true,
		"skipLibCheck": true,
		"ignoreDeprecations": "6.0",
		"baseUrl": ".",
		"paths": {
			"@codebam/cf-workers-telegram-bot": ["../main/src/main.ts"]
		},
		"outDir": "dist"
	}
}
