{
	"name": "worker",
	"version": "7.19.0",
	"private": true,
	"description": "serverless telegram bot on cf workers",
	"main": "./dist/worker.mjs",
	"module": "./dist/worker.mjs",
	"type": "module",
	"scripts": {
		"build": "esbuild ./src/index.ts --bundle --outfile=../../dist/index.js --platform=neutral --format=esm --main-fields=module,main",
		"lint": "eslint src",
		"test": "vitest --config vitest.config.js"
	},
	"author": "codebam",
	"license": "Apache-2.0",
	"dependencies": {
		"@codebam/cf-workers-telegram-bot": "file:../main",
		"marked": "^18.0.3",
		"typedoc": "0.28.19"
	},
	"devDependencies": {
		"@babel/preset-env": "^7.29.5",
		"@cloudflare/vitest-pool-workers": "^0.16.3",
		"@cloudflare/workers-types": "^4.20260510.1",
		"@eslint/js": "^10.0.1",
		"@typescript-eslint/eslint-plugin": "^8.59.2",
		"@typescript-eslint/parser": "^8.59.2",
		"esbuild": "^0.28.0",
		"esbuild-plugin-babel": "^0.2.3",
		"eslint": "^10.3.0",
		"eslint-config-prettier": "^10.1.8",
		"globals": "^17.6.0",
		"prettier": "^3.8.3",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.59.2",
		"vitest": "4.1.5"
	},
	"typedocOptions": {
		"entryPoints": [
			"./src/index.ts"
		]
	}
}